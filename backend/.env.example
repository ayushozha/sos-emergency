# SOS Emergency backend — server-side secrets
# Copy to backend/.env and fill in. This file (.env) is gitignored.

# Required. Get a key at https://featherless.ai/
FEATHERLESS_API_KEY=

# Optional overrides
# FEATHERLESS_MODEL=Qwen/Qwen2.5-72B-Instruct
# FEATHERLESS_BASE_URL=https://api.featherless.ai/v1

# Comma-separated allowed origins. "*" is fine for local dev; lock down for prod.
# CORS_ALLOW_ORIGINS=http://localhost:3000,https://your-app.example.com

# --- OpenAI Realtime voice (gpt-realtime-2 speech-to-speech) ---

# Required for /v1/voice/agent. Get a key at https://platform.openai.com/
OPENAI_API_KEY=

# Optional voice overrides (defaults shown)
# VOICE_REALTIME_MODEL=gpt-realtime-2
# VOICE_REALTIME_VOICE=marin
# VOICE_GREETING=Emergency assistant here. Tell me what's happening.
# VOICE_INPUT_SAMPLE_RATE=24000
# VOICE_OUTPUT_SAMPLE_RATE=24000
# VOICE_DISPATCHER_PROMPT=   # override the built-in emergency-dispatcher prompt