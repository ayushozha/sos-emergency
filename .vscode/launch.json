{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch App (Chrome)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "-d",
        "chrome",
        "--dart-define=BACKEND_BASE=http://localhost:8000"
      ]
    },
    {
      "name": "Launch App (macOS)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "-d",
        "macos",
        "--dart-define=BACKEND_BASE=http://localhost:8000"
      ]
    }
  ]
}
